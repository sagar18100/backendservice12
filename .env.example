# ─────────────────────────────────────────
#   Mobile Help Platform — Backend .env
# ─────────────────────────────────────────

# Server
PORT=5000

# ── MongoDB Atlas ─────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mobile-help-platform?retryWrites=true&w=majority

# ── Admin Contact ─────────────────────────
ADMIN_EMAIL=your-admin@gmail.com
ADMIN_PHONE=+919876543210

# ── Email (Nodemailer via Gmail SMTP) ─────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-smtp@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── Twilio WhatsApp ───────────────────────
# Sign up at https://www.twilio.com/
# Enable WhatsApp Sandbox in Twilio Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio sandbox number (default for testing):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your admin WhatsApp number (with country code):
ADMIN_WHATSAPP=whatsapp:+919876543210

# ── Optional: Auto-reply to user ──────────
# Set to true to send auto-reply WhatsApp to user
# User's phone must be registered with Twilio sandbox
AUTO_REPLY=false

# ── Frontend URL (for CORS) ───────────────
FRONTEND_URL=http://localhost:5173
